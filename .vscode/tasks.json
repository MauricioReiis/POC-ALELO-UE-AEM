            "command": "npx --yes kill-port 8080 || true; npx --yes kill-port 9443 || true; (set -a; source tools/universal-editor/.env; set +a; node tools/universal-editor/universal-editor-service.cjs > /tmp/ue-service.log 2>&1) & node tools/universal-editor/ue-https-frame-proxy.cjs > /tmp/ue-frame-proxy.log 2>&1 & npx --yes wait-on http-get://localhost:8080/ping tcp:9443 --timeout 20000 && curl -k -s -o /dev/null -u admin:admin https://localhost:9443/content/alelo/us/en.html && echo 'UE rodando sem conflitos: service(8080) + frame-proxy(9443). Conexao pronta.' || (echo 'Falha ao iniciar/conectar UE. Veja logs: /tmp/ue-service.log e /tmp/ue-frame-proxy.log'; exit 1)",
